  "keyFeatures": [
    "JWT-based authentication with secure token generation",
    "Kanban board management with role-based access control",
    "Task and column organization with drag-and-drop positioning",
    "Multi-user collaboration via shareable join codes",
    "Entity Framework Core with MySQL database integration"
  ],
  "publicApiSurface": [
    "POST /api/auth/register - Register new user",
    "POST /api/auth/login - Authenticate user",
    "GET /api/board/my - List user's boards",
    "GET /api/board/{id} - Get board details",
    "POST /api/board - Create new board",
    "PUT /api/board/{id} - Update board",
    "DELETE /api/board/{id} - Delete board",
    "POST /api/board/join - Join board with code",
    "POST /api/column - Create column",
    "PUT /api/column/{id} - Update column",
    "PUT /api/column/{id}/move - Reorder column",
    "DELETE /api/column/{id} - Delete column",
    "POST /api/task - Create task",
    "PUT /api/task/{id} - Update task",
    "PUT /api/task/{id}/move - Move task",
    "DELETE /api/task/{id} - Delete task"
  ]
}
